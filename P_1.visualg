algoritmo "P_1"

var
  n1, n2, n3, x : inteiro
inicio

  leia(n1)
  leia(n2)
  leia(n3)

  se n1 > n2 entao

    x <- n1
    n1 <- n2
    n2 <- x

  fimse

  se n2 > n3 entao

    x <- n2
    n2 <- n3
    n3 <- x

    se n1 > n2 entao

      x <- n1
      n1 <- n2
      n2 <- x

    fimse

  fimse

  escreval(n1)
  escreval(n2)
  escreval(n3)

fimalgoritmo
